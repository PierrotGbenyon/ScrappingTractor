        "# Titre\n",
        "\n",
        "fig.text(\n",
        "    0.5, 0.975,\n",
        "    \"TABLEAU DE BORD — MARCHÉ DES CAMIONS TRACTEURS\",\n",
        "    ha='center', va='top',\n",
        "    fontsize=20, fontweight='bold',\n",
        "    color=LIGHT['title']\n",
        ")\n",
        "\n",
        "fig.text(\n",
        "    0.5, 0.955,\n",
        "    f\"{len(df):,} annonces  •  {df['manufacturer'].nunique()} constructeurs\",\n",
        "    ha='center', va='top',\n",
        "    fontsize=11,\n",
        "    color=LIGHT['sub']\n",
        ")\n",
        "\n",
        "# KPI\n",
        "\n",
        "kpi_bg = '#EEF2FF'\n",
        "kpis = [\n",
        "    (\"Prix médian\",  f\"{prix_median:,.0f} €\", LIGHT['accent']),\n",
        "    (\"Prix moyen\",   f\"{prix_moyen:,.0f} €\", LIGHT['accent']),\n",
        "    (\"Kilom. moyen\", f\"{km_moyen/1000:,.0f} k km\", LIGHT['green'])\n",
