        "    for spine in ax_kpi.spines.values():\n",
        "        spine.set_edgecolor(LIGHT['border'])\n",
        "\n",
        "    ax_kpi.set_xticks([])\n",
        "    ax_kpi.set_yticks([])\n",
        "\n",
        "    fig.text(\n",
        "        x + 0.08, 0.915, val,\n",
        "        ha='center', fontsize=13,\n",
        "        fontweight='bold', color=col\n",
        "    )\n",
        "    fig.text(\n",
        "        x + 0.08, 0.899, label,\n",
        "        ha='center', fontsize=9,\n",
        "        color=LIGHT['sub']\n",
        "    )\n",
        "\n",
        "# Grille 2x2\n",
        "\n",
        "gs = gridspec.GridSpec(\n",
        "    2, 2, figure=fig,\n",
        "    hspace=0.28, wspace=0.18,\n",
